-- MINION LOCK
task.spawn(function()

	while task.wait(0.1) do

		if not EverythingActive or not AttackBobMinions then
			CurrentMinionTarget=nil
			continue
		end

		if CurrentMinionTarget and CurrentMinionTarget.Parent then

			if CurrentMinionTarget.Position.Y <= MinionMaxY then
				ScriptedFlyTarget=CurrentMinionTarget.Position
				continue
			else
				CurrentMinionTarget=nil
			end

		end

		for _,obj in ipairs(Workspace:GetDescendants()) do

			if obj.Name=="BobMinion" then

				local part=obj:FindFirstChild("HumanoidRootPart") or obj

				if part and part:IsA("BasePart") then

					if part.Position.Y <= MinionMaxY then
						CurrentMinionTarget=part
						break
					end

				end

			end

		end

	end

end)

-- FLY SYSTEM
local flyPart
local weld

local function ensureFly()

	local char = player.Character or player.CharacterAdded:Wait()
	local root = char:WaitForChild("HumanoidRootPart")

	if not flyPart then

		flyPart=Instance.new("Part")
		flyPart.Size=Vector3.new(1,1,1)
		flyPart.Transparency=1
		flyPart.CanCollide=false
		flyPart.Parent=Workspace

	end

	if not weld then

		weld=Instance.new("Weld")
		weld.Part0=flyPart
		weld.Part1=root
		weld.Parent=flyPart

	end

end

RunService.RenderStepped:Connect(function()

	local char=player.Character
	if not char then return end

	local root=char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	ensureFly()

	local targetPos=nil

	if ScriptedFlyTarget then

		targetPos=ScriptedFlyTarget

	elseif FlyEnabled then

		local move=Vector3.zero

		if UserInputService:IsKeyDown(Enum.KeyCode.W) then move+=Vector3.new(0,0,-1) end
		if UserInputService:IsKeyDown(Enum.KeyCode.S) then move+=Vector3.new(0,0,1) end
		if UserInputService:IsKeyDown(Enum.KeyCode.A) then move+=Vector3.new(-1,0,0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.D) then move+=Vector3.new(1,0,0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.Q) then move+=Vector3.new(0,1,0) end
		if UserInputService:IsKeyDown(Enum.KeyCode.E) then move+=Vector3.new(0,-1,0) end

		if move.Magnitude>0 then
			targetPos=flyPart.Position+move.Unit*FlySpeed
		elseif HoverAboveMap then
			targetPos=Vector3.new(0,50,0)
		end

	end

	if targetPos then

		local dir=targetPos-root.Position

		if dir.Magnitude>0.1 then
			flyPart.CFrame=CFrame.new(root.Position+dir.Unit*FlySpeed)
		end

	end

end)

-- HEADLESS CONTROL BINDING
local function bindBool(folder,name,setter)
	local v = Instance.new("BoolValue")
	v.Name = name
	v.Parent = folder

	v.Changed:Connect(function()
		setter(v.Value)
	end)

	return v
end


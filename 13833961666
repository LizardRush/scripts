-- Fly system
local flyPart
local weld
local flying = false

local function startFly()
	if flying then return end
	local char = player.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	if not flyPart then
		flyPart = Instance.new("Part")
		flyPart.Size = Vector3.new(1,1,1)
		flyPart.Anchored=false
		flyPart.CanCollide=false
		flyPart.Transparency=1
		flyPart.CFrame=root.CFrame
		flyPart.Parent=workspace
	end

	weld = Instance.new("Weld")
	weld.Part0=flyPart
	weld.Part1=root
	weld.C0=CFrame.new()
	weld.Parent=flyPart

	flying=true
end

local function stopFly()
	flying=false
	if weld then weld:Destroy() end
	weld=nil
end

local function getNextMovement()
	local v=Vector3.zero
	if UserInputService:IsKeyDown(Enum.KeyCode.W) then v+=Vector3.new(0,0,-1) end
	if UserInputService:IsKeyDown(Enum.KeyCode.S) then v+=Vector3.new(0,0,1) end
	if UserInputService:IsKeyDown(Enum.KeyCode.A) then v+=Vector3.new(-1,0,0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.D) then v+=Vector3.new(1,0,0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.Q) then v+=Vector3.new(0,1,0) end
	if UserInputService:IsKeyDown(Enum.KeyCode.E) then v+=Vector3.new(0,-1,0) end
	return v
end


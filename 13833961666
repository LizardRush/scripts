-- Helper to get first BasePart of a model
local function getFirstPart(model)
	for _,v in ipairs(model:GetDescendants()) do
		if v:IsA("BasePart") then
			return v
		end
	end
end

-- Track meteors
local Meteors = {}
for _,v in ipairs(workspace:GetDescendants()) do
	if v.Name=="SpiritRock" then
		local part=getFirstPart(v)
		if part then Meteors[v]=part end
	end
end
workspace.DescendantAdded:Connect(function(obj)
	if obj.Name=="SpiritRock" then
		local part=getFirstPart(obj)
		if part then Meteors[obj]=part end
	end
end)

-- Scripted fly / minion targeting
local CurrentMinionTarget = nil
task.spawn(function()
	while true do
		if not EverythingActive then
			CurrentMinionTarget = nil
			ScriptedFlyTarget = nil
			task.wait(0.2)
			continue
		end
		local char = player.Character
		local root = char and char:FindFirstChild("HumanoidRootPart")
		if not root then
			task.wait(0.2)
			continue
		end

		-- Lock onto a single minion until gone/out-of-bounds
		if AttackBobMinions then
			if CurrentMinionTarget and CurrentMinionTarget.Parent and CurrentMinionTarget.Position.Y<=MinionMaxY then
				ScriptedFlyTarget=CurrentMinionTarget.Position
				ScriptedDirection=workspace.bobBoss.HumanoidRootPart.Position
				task.wait(0.05)
				continue
			else
				CurrentMinionTarget=nil
			end
		end

		if AttackBobMinions then
			for _,obj in ipairs(workspace:GetDescendants()) do
				if obj.Name=="BobMinion" then
					local part=obj:IsA("Model") and obj:FindFirstChild("HumanoidRootPart") or obj
					if part and part.Parent and part.Position.Y<=MinionMaxY then
						CurrentMinionTarget=part
						break
					end
				end
			end
		end

		-- Meteors
		local closestDist=math.huge
		local meteorTarget=nil
		if HitMeteors then
			for _,part in pairs(Meteors) do
				if part and part.Parent then
					local d=(root.Position-part.Position).Magnitude
					if d<closestDist then
						closestDist=d
						meteorTarget=part
					end
				end
			end
		end

		if meteorTarget then
			ScriptedFlyTarget=meteorTarget.Position
			ScriptedDirection=workspace.bobBoss.HumanoidRootPart.Position
		elseif CurrentMinionTarget then
			ScriptedFlyTarget=CurrentMinionTarget.Position
			ScriptedDirection=workspace.bobBoss.HumanoidRootPart.Position
		else
			ScriptedFlyTarget=nil
			ScriptedDirection=nil
		end

		task.wait(0.05)
	end
end)

-- Fly logic
RunService.RenderStepped:Connect(function()
	local char=player.Character
	if not char then return end
	local root=char:FindFirstChild("HumanoidRootPart")
	if not root then return end

	startFly()

	local targetPos=nil
	local facePos=nil

	if ScriptedFlyTarget then
		targetPos=ScriptedFlyTarget
		facePos=ScriptedDirection or ScriptedFlyTarget
	elseif FlyEnabled then
		local moveDir=getNextMovement()
		if moveDir.Magnitude>0 then
			targetPos=flyPart.Position+moveDir.Unit*FlySpeed
		elseif HoverAboveMap then
			targetPos=Vector3.new(0,50,0)
		else
			flyPart.Velocity=Vector3.zero
			return
		end
	end

	if targetPos then
		local dir=targetPos-root.Position
		local dist=dir.Magnitude
		if dist>0.1 then
			if facePos then
				root.CFrame=CFrame.lookAt(root.Position,facePos)
			end
			flyPart.CFrame=CFrame.new(root.Position+dir.Unit*FlySpeed)
		end
	end
end)
